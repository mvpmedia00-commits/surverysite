{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "surverysite.vercel.app"
        }
      ],
      "destination": "https://mvpstats.xyz/$1",
      "permanent": true
    },
    {
      "source": "/artistic-nude-landing",
      "destination": "/artistic-survey",
      "permanent": true
    },
    {
      "source": "/artistic-nude-survey",
      "destination": "/artistic-survey",
      "permanent": true
    },
    {
      "source": "/artistic-nude-survey.html",
      "destination": "/artistic-survey",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
